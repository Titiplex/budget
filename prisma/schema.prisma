generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                 Int                     @id @default(autoincrement())
  name               String
  type               AccountType
  currency           String                  @default("CAD")
  description        String?
  institutionCountry String?
  institutionRegion  String?
  taxReportingType   AccountTaxReportingType @default(STANDARD)
  openedAt           DateTime?
  closedAt           DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  transactions        Transaction[]
  recurringTemplates  RecurringTransactionTemplate[]
  transferPeerForRows Transaction[]                  @relation("TransactionTransferPeer")

  wealthPortfolio   Portfolio?
  wealthLiabilities Liability[]
}

model Category {
  id                 Int                            @id @default(autoincrement())
  name               String                         @unique
  kind               TransactionKind
  color              String?
  description        String?
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  transactions       Transaction[]
  budgetTargets      BudgetTarget[]
  recurringTemplates RecurringTransactionTemplate[]
}

model Transaction {
  id                  Int                @id @default(autoincrement())
  label               String
  amount              Float
  sourceAmount        Float?
  sourceCurrency      String?
  conversionMode      ConversionMode     @default(NONE)
  exchangeRate        Float?
  exchangeProvider    String?
  exchangeDate        DateTime?
  kind                TransactionKind
  date                DateTime
  note                String?
  taxCategory         TaxIncomeCategory?
  taxSourceCountry    String?
  taxSourceRegion     String?
  taxTreatment        TaxTreatment       @default(UNKNOWN)
  taxWithheldAmount   Float?
  taxWithheldCurrency String?
  taxWithheldCountry  String?
  taxDocumentRef      String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  accountId Int
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  transferGroup         String?
  transferDirection     TransferDirection?
  transferPeerAccountId Int?
  transferPeerAccount   Account?           @relation("TransactionTransferPeer", fields: [transferPeerAccountId], references: [id], onDelete: SetNull)
}

model TaxProfile {
  id               Int      @id @default(autoincrement())
  year             Int
  residenceCountry String
  residenceRegion  String?
  currency         String   @default("CAD")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([year, residenceCountry, residenceRegion])
}

model BudgetTarget {
  id        Int          @id @default(autoincrement())
  name      String
  amount    Float
  period    BudgetPeriod
  startDate DateTime
  endDate   DateTime?
  currency  String       @default("CAD")
  isActive  Boolean      @default(true)
  note      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model RecurringTransactionTemplate {
  id                 Int                @id @default(autoincrement())
  label              String
  sourceAmount       Float
  sourceCurrency     String
  accountAmount      Float?
  conversionMode     ConversionMode     @default(NONE)
  exchangeRate       Float?
  exchangeProvider   String?
  kind               TransactionKind
  note               String?
  frequency          RecurringFrequency
  intervalCount      Int                @default(1)
  startDate          DateTime
  nextOccurrenceDate DateTime
  endDate            DateTime?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  accountId Int
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model Asset {
  id                 Int                 @id @default(autoincrement())
  name               String
  type               WealthAssetType
  status             WealthRecordStatus  @default(ACTIVE)
  currency           String              @default("CAD")
  valuationMode      WealthValuationMode @default(MANUAL)
  currentValue       Float               @default(0)
  includeInNetWorth  Boolean             @default(true)
  ownershipPercent   Float               @default(100)
  acquisitionValue   Float?
  acquiredAt         DateTime?
  valueAsOf          DateTime?
  institutionName    String?
  institutionCountry String?
  institutionRegion  String?
  note               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  securedLiabilities Liability[]

  @@index([type])
  @@index([status])
  @@index([currency])
}

model Portfolio {
  id                 Int                 @id @default(autoincrement())
  name               String
  type               PortfolioType
  status             WealthRecordStatus  @default(ACTIVE)
  currency           String              @default("CAD")
  institutionName    String?
  institutionCountry String?
  institutionRegion  String?
  taxWrapper         PortfolioTaxWrapper @default(NONE)
  valuationMode      WealthValuationMode @default(MANUAL)
  currentValue       Float               @default(0)
  includeInNetWorth  Boolean             @default(true)
  ownershipPercent   Float               @default(100)
  cashBalance        Float               @default(0)
  valueAsOf          DateTime?
  note               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  accountId Int?     @unique
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  holdings HoldingLot[]

  @@index([type])
  @@index([status])
  @@index([currency])
  @@index([institutionCountry, institutionRegion])
}

model HoldingLot {
  id          Int               @id @default(autoincrement())
  name        String
  symbol      String?
  assetClass  HoldingAssetClass
  quantity    Float             @default(0)
  currency    String            @default("CAD")
  unitCost    Float?
  costBasis   Float?
  unitPrice   Float?
  marketValue Float?
  openedAt    DateTime?
  valueAsOf   DateTime?
  note        String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  portfolioId Int
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  priceSnapshots PriceSnapshot[]

  @@index([portfolioId])
  @@index([assetClass])
  @@index([symbol])
  @@index([currency])
}

model PriceSnapshot {
  id        Int                 @id @default(autoincrement())
  unitPrice Float
  currency  String              @default("CAD")
  pricedAt  DateTime
  source    PriceSnapshotSource @default(MANUAL)
  note      String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  holdingLotId Int
  holdingLot   HoldingLot @relation(fields: [holdingLotId], references: [id], onDelete: Cascade)

  @@unique([holdingLotId, pricedAt, currency, source])
  @@index([pricedAt])
  @@index([currency])
}

model Liability {
  id                 Int                        @id @default(autoincrement())
  name               String
  type               LiabilityType
  status             WealthRecordStatus         @default(ACTIVE)
  currency           String                     @default("CAD")
  currentBalance     Float                      @default(0)
  includeInNetWorth  Boolean                    @default(true)
  initialAmount      Float?
  interestRate       Float?
  minimumPayment     Float?
  paymentFrequency   LiabilityPaymentFrequency?
  rateType           LiabilityRateType          @default(UNKNOWN)
  lenderName         String?
  institutionCountry String?
  institutionRegion  String?
  openedAt           DateTime?
  dueAt              DateTime?
  balanceAsOf        DateTime?
  note               String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  securedAssetId Int?
  securedAsset   Asset? @relation(fields: [securedAssetId], references: [id], onDelete: SetNull)

  accountId Int?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@index([currency])
  @@index([securedAssetId])
  @@index([accountId])
}

model NetWorthSnapshot {
  id                     Int                    @id @default(autoincrement())
  snapshotDate           DateTime
  currency               String                 @default("CAD")
  totalStandaloneAssets  Float                  @default(0)
  totalPortfolios        Float                  @default(0)
  totalAssets            Float                  @default(0)
  totalLiabilities       Float                  @default(0)
  netWorth               Float                  @default(0)
  source                 NetWorthSnapshotSource @default(MANUAL)
  assetBreakdownJson     String?
  portfolioBreakdownJson String?
  liabilityBreakdownJson String?
  note                   String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@unique([snapshotDate, currency, source])
  @@index([snapshotDate])
  @@index([currency])
}

enum AccountType {
  CASH
  BANK
  SAVINGS
  CREDIT
  INVESTMENT
  OTHER
}

enum AccountTaxReportingType {
  STANDARD
  BANK
  CASH
  BROKERAGE
  CRYPTO
  LIFE_INSURANCE
  RETIREMENT
  LOAN
  OTHER
}

enum TransactionKind {
  INCOME
  EXPENSE
  TRANSFER
}

enum ConversionMode {
  NONE
  MANUAL
  AUTOMATIC
}

enum BudgetPeriod {
  MONTHLY
  YEARLY
  CUSTOM
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum TransferDirection {
  OUT
  IN
}

enum TaxIncomeCategory {
  EMPLOYMENT
  BUSINESS
  INTEREST
  DIVIDEND
  CAPITAL_GAIN
  RENTAL
  PENSION
  BENEFIT
  GIFT
  REFUND
  TRANSFER
  OTHER
}

enum TaxTreatment {
  UNKNOWN
  NOT_TAXABLE
  TAXABLE_NO_WITHHOLDING
  TAX_WITHHELD_AT_SOURCE
  FOREIGN_TAX_CREDIT_CANDIDATE
  TREATY_EXEMPT_CANDIDATE
  REVIEW_REQUIRED
}

enum WealthAssetType {
  CASH
  REAL_ESTATE
  VEHICLE
  COLLECTIBLE
  BUSINESS
  PRIVATE_EQUITY
  CRYPTO
  OTHER
}

enum PortfolioType {
  TAXABLE_BROKERAGE
  RETIREMENT
  EDUCATION
  CRYPTO
  SAVINGS_INVESTMENT
  OTHER
}

enum PortfolioTaxWrapper {
  NONE
  TFSA
  RRSP
  FHSA
  RESP
  PEA
  ASSURANCE_VIE
  PER
  OTHER
}

enum HoldingAssetClass {
  CASH
  EQUITY
  ETF
  MUTUAL_FUND
  BOND
  CRYPTO
  OPTION
  COMMODITY
  REAL_ESTATE_FUND
  OTHER
}

enum LiabilityType {
  MORTGAGE
  STUDENT_LOAN
  PERSONAL_LOAN
  CREDIT_CARD
  LINE_OF_CREDIT
  AUTO_LOAN
  TAX_DEBT
  OTHER
}

enum WealthRecordStatus {
  ACTIVE
  ARCHIVED
}

enum WealthValuationMode {
  MANUAL
  CALCULATED
  IMPORTED
}

enum PriceSnapshotSource {
  MANUAL
  IMPORTED
  API
}

enum NetWorthSnapshotSource {
  MANUAL
  GENERATED
  IMPORTED
}

enum LiabilityPaymentFrequency {
  MONTHLY
  BIWEEKLY
  WEEKLY
  YEARLY
  OTHER
}

enum LiabilityRateType {
  FIXED
  VARIABLE
  PROMOTIONAL
  UNKNOWN
}
