generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                 Int                     @id @default(autoincrement())
  name               String
  type               AccountType
  currency           String                  @default("CAD")
  description        String?
  institutionCountry String?
  institutionRegion  String?
  taxReportingType   AccountTaxReportingType @default(STANDARD)
  openedAt           DateTime?
  closedAt           DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  transactions        Transaction[]
  recurringTemplates  RecurringTransactionTemplate[]
  transferPeerForRows Transaction[]                  @relation("TransactionTransferPeer")

  wealthPortfolio   Portfolio?
  wealthLiabilities Liability[]

  investmentPositions InvestmentPosition[]
  investmentMovements InvestmentMovement[]
  importSources       ImportSource[]
}

model Category {
  id          Int             @id @default(autoincrement())
  name        String          @unique
  kind        TransactionKind
  color       String?
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  transactions       Transaction[]
  budgetTargets      BudgetTarget[]
  recurringTemplates RecurringTransactionTemplate[]
}

model Transaction {
  id                  Int                @id @default(autoincrement())
  label               String
  amount              Float
  sourceAmount        Float?
  sourceCurrency      String?
  conversionMode      ConversionMode     @default(NONE)
  exchangeRate        Float?
  exchangeProvider    String?
  exchangeDate        DateTime?
  kind                TransactionKind
  date                DateTime
  note                String?
  taxCategory         TaxIncomeCategory?
  taxSourceCountry    String?
  taxSourceRegion     String?
  taxTreatment        TaxTreatment       @default(UNKNOWN)
  taxWithheldAmount   Float?
  taxWithheldCurrency String?
  taxWithheldCountry  String?
  taxDocumentRef      String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  accountId             Int
  account               Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId            Int?
  category              Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transferGroup         String?
  transferDirection     TransferDirection?
  transferPeerAccountId Int?
  transferPeerAccount   Account?           @relation("TransactionTransferPeer", fields: [transferPeerAccountId], references: [id], onDelete: SetNull)

  importReconciliationCandidates ImportReconciliationDecision[] @relation("ImportDecisionCandidateTransaction")
  importAppliedLinks             ImportAppliedLink[]            @relation("ImportAppliedTransaction")
}

model TaxProfile {
  id               Int      @id @default(autoincrement())
  year             Int
  residenceCountry String
  residenceRegion  String?
  currency         String   @default("CAD")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([year, residenceCountry, residenceRegion])
}

model BudgetTarget {
  id        Int          @id @default(autoincrement())
  name      String
  amount    Float
  period    BudgetPeriod
  startDate DateTime
  endDate   DateTime?
  currency  String       @default("CAD")
  isActive  Boolean      @default(true)
  note      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model RecurringTransactionTemplate {
  id                 Int                @id @default(autoincrement())
  label              String
  sourceAmount       Float
  sourceCurrency     String
  accountAmount      Float?
  conversionMode     ConversionMode     @default(NONE)
  exchangeRate       Float?
  exchangeProvider   String?
  kind               TransactionKind
  note               String?
  frequency          RecurringFrequency
  intervalCount      Int                @default(1)
  startDate          DateTime
  nextOccurrenceDate DateTime
  endDate            DateTime?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  accountId  Int
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model Asset {
  id                 Int                 @id @default(autoincrement())
  name               String
  type               WealthAssetType
  status             WealthRecordStatus  @default(ACTIVE)
  currency           String              @default("CAD")
  valuationMode      WealthValuationMode @default(MANUAL)
  currentValue       Float               @default(0)
  includeInNetWorth  Boolean             @default(true)
  ownershipPercent   Float               @default(100)
  acquisitionValue   Float?
  acquiredAt         DateTime?
  valueAsOf          DateTime?
  institutionName    String?
  institutionCountry String?
  institutionRegion  String?
  note               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  securedLiabilities Liability[]

  marketInstrumentId Int?
  marketInstrument   MarketInstrument? @relation("AssetMarketInstrument", fields: [marketInstrumentId], references: [id], onDelete: SetNull)

  financialGoals FinancialGoal[] @relation("FinancialGoalAsset")

  importReconciliationCandidates ImportReconciliationDecision[] @relation("ImportDecisionCandidateAsset")
  importAppliedLinks             ImportAppliedLink[]            @relation("ImportAppliedAsset")

  @@index([type])
  @@index([status])
  @@index([currency])
  @@index([marketInstrumentId])
}

model Portfolio {
  id                 Int                 @id @default(autoincrement())
  name               String
  type               PortfolioType
  status             WealthRecordStatus  @default(ACTIVE)
  currency           String              @default("CAD")
  institutionName    String?
  institutionCountry String?
  institutionRegion  String?
  taxWrapper         PortfolioTaxWrapper @default(NONE)
  valuationMode      WealthValuationMode @default(MANUAL)
  currentValue       Float               @default(0)
  includeInNetWorth  Boolean             @default(true)
  ownershipPercent   Float               @default(100)
  cashBalance        Float               @default(0)
  valueAsOf          DateTime?
  note               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  accountId Int?         @unique
  account   Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  holdings  HoldingLot[]

  investmentPositions InvestmentPosition[]
  investmentMovements InvestmentMovement[]
  financialGoals      FinancialGoal[]      @relation("FinancialGoalPortfolio")

  @@index([type])
  @@index([status])
  @@index([currency])
  @@index([institutionCountry, institutionRegion])
}

model MarketInstrument {
  id Int @id @default(autoincrement())

  instrumentKey String @unique

  symbol               String
  name                 String?
  instrumentType       MarketInstrumentType @default(OTHER)
  exchange             String?
  quoteCurrency        String               @default("CAD")
  provider             String?
  providerInstrumentId String?

  currentPrice         Float?
  currentPriceCurrency String?
  currentPriceQuotedAt DateTime?
  currentPriceProvider String?
  freshnessStatus      MarketPriceFreshnessStatus @default(UNKNOWN)
  freshnessCheckedAt   DateTime?
  staleAfterHours      Int                        @default(24)
  isActive             Boolean                    @default(true)
  note                 String?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  standaloneAssets      Asset[]                @relation("AssetMarketInstrument")
  holdingLots           HoldingLot[]
  investmentInstruments InvestmentInstrument[]
  priceSnapshots        PriceSnapshot[]

  @@unique([symbol, exchange, quoteCurrency, provider])
  @@unique([provider, providerInstrumentId])
  @@index([symbol])
  @@index([exchange])
  @@index([quoteCurrency])
  @@index([freshnessStatus])
}

model HoldingLot {
  id          Int               @id @default(autoincrement())
  name        String
  symbol      String?
  assetClass  HoldingAssetClass
  quantity    Float             @default(0)
  currency    String            @default("CAD")
  unitCost    Float?
  costBasis   Float?
  unitPrice   Float?
  marketValue Float?
  openedAt    DateTime?
  valueAsOf   DateTime?
  note        String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  portfolioId        Int
  portfolio          Portfolio         @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  priceSnapshots     PriceSnapshot[]
  marketInstrumentId Int?
  marketInstrument   MarketInstrument? @relation(fields: [marketInstrumentId], references: [id], onDelete: SetNull)

  @@index([portfolioId])
  @@index([assetClass])
  @@index([symbol])
  @@index([currency])
  @@index([marketInstrumentId])
}

model PriceSnapshot {
  id              Int                        @id @default(autoincrement())
  unitPrice       Float
  currency        String                     @default("CAD")
  pricedAt        DateTime
  provider        String                     @default("manual")
  source          PriceSnapshotSource        @default(MANUAL)
  freshnessStatus MarketPriceFreshnessStatus @default(UNKNOWN)
  retrievedAt     DateTime                   @default(now())
  note            String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  holdingLotId         Int?
  holdingLot           HoldingLot?         @relation(fields: [holdingLotId], references: [id], onDelete: Cascade)
  marketInstrumentId   Int?
  marketInstrument     MarketInstrument?   @relation(fields: [marketInstrumentId], references: [id], onDelete: Cascade)
  investmentPositionId Int?
  investmentPosition   InvestmentPosition? @relation(fields: [investmentPositionId], references: [id], onDelete: Cascade)

  @@unique([holdingLotId, pricedAt, currency, source])
  @@unique([marketInstrumentId, pricedAt, currency, provider])
  @@unique([investmentPositionId, pricedAt, currency, provider])
  @@index([pricedAt])
  @@index([currency])
  @@index([provider])
  @@index([freshnessStatus])
  @@index([marketInstrumentId])
  @@index([investmentPositionId])
}

model InvestmentInstrument {
  id               Int                        @id @default(autoincrement())
  instrumentKey    String                     @unique
  name             String
  symbol           String?
  assetClass       InvestmentAssetClass
  geographicRegion InvestmentGeographicRegion @default(GLOBAL)
  sector           InvestmentSector?
  currency         String                     @default("CAD")
  exchange         String?
  isin             String?
  cusip            String?
  issuer           String?
  note             String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  marketInstrumentId Int?
  marketInstrument   MarketInstrument?    @relation(fields: [marketInstrumentId], references: [id], onDelete: SetNull)
  positions          InvestmentPosition[]
  movements          InvestmentMovement[]

  @@index([assetClass])
  @@index([geographicRegion])
  @@index([sector])
  @@index([symbol])
  @@index([currency])
  @@index([marketInstrumentId])
}

model InvestmentPosition {
  id              Int                @id @default(autoincrement())
  status          WealthRecordStatus @default(ACTIVE)
  quantity        Float              @default(0)
  averageUnitCost Float?
  costBasis       Float?
  costCurrency    String             @default("CAD")
  openedAt        DateTime?
  closedAt        DateTime?
  valueAsOf       DateTime?
  note            String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  portfolioId  Int
  portfolio    Portfolio            @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  accountId    Int
  account      Account              @relation(fields: [accountId], references: [id], onDelete: Restrict)
  instrumentId Int
  instrument   InvestmentInstrument @relation(fields: [instrumentId], references: [id], onDelete: Restrict)

  movements      InvestmentMovement[]
  priceSnapshots PriceSnapshot[]

  @@unique([portfolioId, accountId, instrumentId])
  @@index([portfolioId])
  @@index([accountId])
  @@index([instrumentId])
  @@index([status])
}

model InvestmentMovement {
  id             Int                    @id @default(autoincrement())
  type           InvestmentMovementType
  quantity       Float?
  unitPrice      Float?
  priceCurrency  String                 @default("CAD")
  cashAmount     Float?
  cashCurrency   String                 @default("CAD")
  feeAmount      Float                  @default(0)
  feeCurrency    String                 @default("CAD")
  operationDate  DateTime
  settlementDate DateTime?
  externalRef    String?
  note           String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  portfolioId  Int
  portfolio    Portfolio             @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  accountId    Int
  account      Account               @relation(fields: [accountId], references: [id], onDelete: Restrict)
  instrumentId Int?
  instrument   InvestmentInstrument? @relation(fields: [instrumentId], references: [id], onDelete: Restrict)
  positionId   Int?
  position     InvestmentPosition?   @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@unique([accountId, externalRef])
  @@index([portfolioId])
  @@index([accountId])
  @@index([instrumentId])
  @@index([positionId])
  @@index([type])
  @@index([operationDate])
}

model Liability {
  id                 Int                        @id @default(autoincrement())
  name               String
  type               LiabilityType
  status             WealthRecordStatus         @default(ACTIVE)
  currency           String                     @default("CAD")
  currentBalance     Float                      @default(0)
  includeInNetWorth  Boolean                    @default(true)
  initialAmount      Float?
  interestRate       Float?
  minimumPayment     Float?
  paymentFrequency   LiabilityPaymentFrequency?
  rateType           LiabilityRateType          @default(UNKNOWN)
  lenderName         String?
  institutionCountry String?
  institutionRegion  String?
  openedAt           DateTime?
  dueAt              DateTime?
  balanceAsOf        DateTime?
  note               String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  securedAssetId Int?
  securedAsset   Asset?   @relation(fields: [securedAssetId], references: [id], onDelete: SetNull)
  accountId      Int?
  account        Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  financialGoals FinancialGoal[] @relation("FinancialGoalLiability")

  @@index([type])
  @@index([status])
  @@index([currency])
  @@index([securedAssetId])
  @@index([accountId])
}

model NetWorthSnapshot {
  id                     Int                    @id @default(autoincrement())
  snapshotDate           DateTime
  currency               String                 @default("CAD")
  totalStandaloneAssets  Float                  @default(0)
  totalPortfolios        Float                  @default(0)
  totalAssets            Float                  @default(0)
  totalLiabilities       Float                  @default(0)
  netWorth               Float                  @default(0)
  source                 NetWorthSnapshotSource @default(MANUAL)
  assetBreakdownJson     String?
  portfolioBreakdownJson String?
  liabilityBreakdownJson String?
  note                   String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  financialGoals FinancialGoal[] @relation("FinancialGoalBaselineNetWorthSnapshot")

  @@unique([snapshotDate, currency, source])
  @@index([snapshotDate])
  @@index([currency])
}

model FinancialGoal {
  id             Int                 @id @default(autoincrement())
  name           String
  type           FinancialGoalType
  targetAmount   Float
  currency       String              @default("CAD")
  targetDate     DateTime?
  startingAmount Float?
  status         FinancialGoalStatus @default(ACTIVE)
  priority       Int?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  trackedAssetId             Int?
  trackedAsset               Asset?            @relation("FinancialGoalAsset", fields: [trackedAssetId], references: [id], onDelete: SetNull)
  trackedPortfolioId         Int?
  trackedPortfolio           Portfolio?        @relation("FinancialGoalPortfolio", fields: [trackedPortfolioId], references: [id], onDelete: SetNull)
  trackedLiabilityId         Int?
  trackedLiability           Liability?        @relation("FinancialGoalLiability", fields: [trackedLiabilityId], references: [id], onDelete: SetNull)
  baselineNetWorthSnapshotId Int?
  baselineNetWorthSnapshot   NetWorthSnapshot? @relation("FinancialGoalBaselineNetWorthSnapshot", fields: [baselineNetWorthSnapshotId], references: [id], onDelete: SetNull)

  projectionSettings ProjectionSetting[]
  projectionResults  ProjectionResult[]

  @@index([type])
  @@index([status])
  @@index([currency])
  @@index([priority])
  @@index([targetDate])
  @@index([trackedAssetId])
  @@index([trackedPortfolioId])
  @@index([trackedLiabilityId])
  @@index([baselineNetWorthSnapshotId])
}

model ProjectionScenario {
  id          Int                    @id @default(autoincrement())
  name        String                 @unique
  kind        ProjectionScenarioKind @default(CUSTOM)
  description String?
  isDefault   Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  settings ProjectionSetting[]
  results  ProjectionResult[]

  @@index([kind])
  @@index([isDefault])
}

model ProjectionSetting {
  id                        Int      @id @default(autoincrement())
  projectionHorizonMonths   Int
  displayCurrency           String   @default("CAD")
  estimatedMonthlySurplus   Float    @default(0)
  manualMonthlyContribution Float?
  annualGrowthRate          Float?
  notes                     String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  goalId     Int
  goal       FinancialGoal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  scenarioId Int
  scenario   ProjectionScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  results ProjectionResult[]

  @@unique([goalId, scenarioId])
  @@index([goalId])
  @@index([scenarioId])
  @@index([displayCurrency])
}

model ProjectionResult {
  id                 Int                   @id @default(autoincrement())
  projectionMonth    DateTime
  projectedValue     Float
  remainingAmount    Float
  progressPercent    Float
  estimatedReachDate DateTime?
  reachStatus        ProjectionReachStatus @default(UNKNOWN)
  calculatedAt       DateTime              @default(now())
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  goalId     Int
  goal       FinancialGoal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  scenarioId Int
  scenario   ProjectionScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  settingId  Int?
  setting    ProjectionSetting? @relation(fields: [settingId], references: [id], onDelete: SetNull)

  @@unique([goalId, scenarioId, projectionMonth])
  @@index([goalId])
  @@index([scenarioId])
  @@index([settingId])
  @@index([projectionMonth])
  @@index([reachStatus])
}

model ImportSource {
  id               Int              @id @default(autoincrement())
  sourceKey        String           @unique
  name             String
  provider         String
  sourceType       ImportSourceType @default(MANUAL_FILE)
  importType       ImportType       @default(TRANSACTIONS)
  defaultCurrency  String           @default("CAD")
  externalSourceId String?
  isActive         Boolean          @default(true)
  metadataJson     String?
  note             String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  defaultAccountId Int?
  defaultAccount   Account? @relation(fields: [defaultAccountId], references: [id], onDelete: SetNull)

  batches ImportBatch[]

  @@index([provider])
  @@index([sourceType])
  @@index([importType])
  @@index([defaultAccountId])
  @@index([isActive])
}

model ImportBatch {
  id                   Int          @id @default(autoincrement())
  status               ImportStatus @default(DRAFT)
  importType           ImportType   @default(TRANSACTIONS)
  provider             String?
  fileName             String?
  fileHash             String?
  defaultCurrency      String       @default("CAD")
  parserVersion        String?
  sourceMetadataJson   String?
  retentionPolicyJson  String?
  rowCount             Int          @default(0)
  errorCount           Int          @default(0)
  duplicateCount       Int          @default(0)
  importedAt           DateTime     @default(now())
  parsedAt             DateTime?
  previewedAt          DateTime?
  appliedAt            DateTime?
  cancelledAt          DateTime?
  note                 String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  sourceId Int?
  source   ImportSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  rawRows        ImportRawRow[]
  normalizedRows ImportNormalizedRow[]
  errors         ImportError[]
  decisions      ImportReconciliationDecision[]
  appliedLinks   ImportAppliedLink[]

  @@index([sourceId])
  @@index([status])
  @@index([importType])
  @@index([provider])
  @@index([fileHash])
  @@index([importedAt])
}

model ImportRawRow {
  id        Int             @id @default(autoincrement())
  rowNumber Int
  rawText   String?
  rawJson   String
  rawHash   String?
  status    ImportRowStatus @default(RAW)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  batchId Int
  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  normalizedRows ImportNormalizedRow[]
  errors         ImportError[]

  @@unique([batchId, rowNumber])
  @@index([batchId])
  @@index([status])
  @@index([rawHash])
}

model ImportNormalizedRow {
  id                  Int              @id @default(autoincrement())
  rowNumber           Int
  status              ImportRowStatus  @default(NORMALIZED)
  targetKind          ImportTargetKind @default(TRANSACTION)
  normalizedJson      String
  transactionDate     DateTime?
  label               String?
  amount              Float?
  currency            String?
  accountName         String?
  externalRef         String?
  duplicateKey        String?
  duplicateConfidence Float?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  batchId Int
  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  rawRowId Int?
  rawRow   ImportRawRow? @relation(fields: [rawRowId], references: [id], onDelete: SetNull)

  errors       ImportError[]
  decisions    ImportReconciliationDecision[]
  appliedLinks ImportAppliedLink[]

  @@unique([batchId, rowNumber])
  @@index([batchId])
  @@index([rawRowId])
  @@index([status])
  @@index([targetKind])
  @@index([transactionDate])
  @@index([duplicateKey])
}

model ImportError {
  id          Int                 @id @default(autoincrement())
  stage       ImportErrorStage
  severity    ImportErrorSeverity @default(ERROR)
  code        String
  message     String
  field       String?
  detailsJson String?
  createdAt   DateTime            @default(now())

  batchId Int
  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  rawRowId Int?
  rawRow   ImportRawRow? @relation(fields: [rawRowId], references: [id], onDelete: SetNull)

  normalizedRowId Int?
  normalizedRow   ImportNormalizedRow? @relation(fields: [normalizedRowId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([rawRowId])
  @@index([normalizedRowId])
  @@index([stage])
  @@index([severity])
  @@index([code])
}

model ImportReconciliationDecision {
  id            Int                 @id @default(autoincrement())
  action        ImportReconciliationAction
  status        ImportDecisionStatus @default(PENDING)
  confidence    Float?
  reason        String?
  decisionJson  String?
  decidedBy     String?
  decidedAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  batchId Int
  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  normalizedRowId Int
  normalizedRow   ImportNormalizedRow @relation(fields: [normalizedRowId], references: [id], onDelete: Cascade)

  candidateTransactionId Int?
  candidateTransaction   Transaction? @relation("ImportDecisionCandidateTransaction", fields: [candidateTransactionId], references: [id], onDelete: SetNull)

  candidateAssetId Int?
  candidateAsset   Asset? @relation("ImportDecisionCandidateAsset", fields: [candidateAssetId], references: [id], onDelete: SetNull)

  appliedLinks ImportAppliedLink[]

  @@index([batchId])
  @@index([normalizedRowId])
  @@index([candidateTransactionId])
  @@index([candidateAssetId])
  @@index([action])
  @@index([status])
  @@index([decidedAt])
}

model ImportAppliedLink {
  id                 Int                     @id @default(autoincrement())
  entityType         ImportAppliedEntityType
  operation          ImportAppliedOperation
  entitySnapshotJson String?
  appliedAt          DateTime                @default(now())
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  batchId Int
  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  normalizedRowId Int?
  normalizedRow   ImportNormalizedRow? @relation(fields: [normalizedRowId], references: [id], onDelete: SetNull)

  decisionId Int?
  decision   ImportReconciliationDecision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  transactionId Int?
  transaction   Transaction? @relation("ImportAppliedTransaction", fields: [transactionId], references: [id], onDelete: SetNull)

  assetId Int?
  asset   Asset? @relation("ImportAppliedAsset", fields: [assetId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([normalizedRowId])
  @@index([decisionId])
  @@index([transactionId])
  @@index([assetId])
  @@index([entityType])
  @@index([operation])
  @@index([appliedAt])
}

enum ImportSourceType {
  MANUAL_FILE
  CSV_FILE
  OFX_FILE
  QIF_FILE
  API
  SYNC
  OTHER
}

enum ImportType {
  TRANSACTIONS
  ASSETS
  INVESTMENTS
  NET_WORTH
  MIXED
  OTHER
}

enum ImportStatus {
  DRAFT
  PARSED
  PREVIEWED
  PARTIALLY_APPLIED
  APPLIED
  FAILED
  CANCELLED
}

enum ImportRowStatus {
  RAW
  NORMALIZED
  VALID
  INVALID
  DUPLICATE
  RECONCILED
  APPLIED
  SKIPPED
}

enum ImportTargetKind {
  TRANSACTION
  ASSET
  PORTFOLIO
  HOLDING
  INVESTMENT_MOVEMENT
  PRICE_SNAPSHOT
  UNKNOWN
}

enum ImportErrorStage {
  PARSING
  NORMALIZATION
  VALIDATION
  RECONCILIATION
  APPLY
}

enum ImportErrorSeverity {
  INFO
  WARNING
  ERROR
}

enum ImportDecisionStatus {
  PENDING
  ACCEPTED
